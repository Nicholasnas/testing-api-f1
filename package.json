{
  "name": "f1-api-testing",
  "version": "1.0.0",
  "description": "F1 API automated tests using Postman e Newman",
  "scripts": {
    "test": "npm run test:all",
    "test:dev": "npm-run-all --continue-on-error --sequential test:dev:*",
    "test:dev:1-henrique": "newman run collections/f1api.postman_collection_Henrique.json -e environments/f1api.environment.json",
    "test:dev:2-douglas": "newman run collections/f1api.postman_collection_Douglas.json -e environments/f1api.environment.json",
    "test:dev:3-nicholas": "newman run collections/f1.api.postman_collection_Nicholas.json -e environments/f1api.environment.json",
    "test:dev:4-jimenez": "newman run collections/f1api.postman_collection_Otavio_Jimenez.json -e environments/f1api.environment.json",
    "test:dev:5-augusto": "newman run collections/f1api.postman_collection_Otavio_Augusto.json -e environments/f1api.environment.json",
    "test:all": "node run-tests.js",
    "test:relatorio": "npm run test:all",
    "test:otavio-jimenez:json": "newman run collections/f1api.postman_collection_Otavio_Jimenez.json -e environments/f1api.environment.json -r cli,json --reporter-json-export relatorio_Otavio_Jimenez.json"
  },
  "devDependencies": {
    "newman": "^6.2.2",
    "newman-reporter-htmlextra": "^1.23.0",
    "npm-run-all": "^4.1.5"
  }
}