							"const jsonData = pm.response.json();",
							"pm.test('TC-020: Validar estrutura de erro', () => {",
							"  pm.expect(jsonData.message).to.be.a('string');",
							"  pm.expect(jsonData.status).to.eql(404);",
							"});"
