	"item": [
		{
			"name": "TC-019 - Drivers Championship 2021 (Validação Funcional)",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('TC-019: Status deve ser 200 OK', () => { pm.response.to.have.status(200); });",
							"pm.test('TC-019: Resposta deve ser JSON', () => { pm.response.to.be.json; });",
							"pm.test('TC-019: Tempo de resposta < 5000ms', () => { pm.expect(pm.response.responseTime).to.be.below(5000); });",
							"const jsonData = pm.response.json();",
							"pm.test('TC-019: Deve retornar lista de pilotos', () => {",
							"  pm.expect(jsonData).to.be.an('array');",
							"  pm.expect(jsonData.length).to.be.above(0);",
							"});",
							"pm.test('TC-019: Validar contrato básico', () => {",
							"  const piloto = jsonData[0];",
							"  pm.expect(piloto.position).to.be.a('number');",
							"  pm.expect(piloto.driverId).to.be.a('string');",
							"  pm.expect(piloto.points).to.be.a('number');",
							"  pm.expect(piloto.wins).to.be.a('number');",
							"  pm.expect(piloto.team).to.be.a('string');",
							"  pm.expect(piloto.season).to.eql(2021);",
							"});"
						]
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/2021/drivers-championship",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"2021",
						"drivers-championship"
					]
				}
			},
			"response": []
		},
