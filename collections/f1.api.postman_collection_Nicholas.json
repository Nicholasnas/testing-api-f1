    {
      "name": "TC-006 - Ordenação do Campeonato",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('TC-006: Status deve ser 200 OK', () => { pm.response.to.have.status(200); });",
              "const jsonData = pm.response.json();",
              "pm.test('TC-006: Ranking deve estar ordenado por posição', () => {",
              "  for (let i = 1; i < jsonData.length; i++) {",
              "    pm.expect(jsonData[i].position).to.be.above(jsonData[i - 1].position);",
              "  }",
              "});"
            ]
          }
        }
