{
  "info": {
    "_postman_id": "e57f7df9-b29d-4312-b143-0d437f728da3",
    "name": "F1 API Tests - Standings",
    "description": "Testes de integração do endpoint Drivers Championship",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "36978201"
  },
  "item": [
    {
      "name": "TC-005 - Drivers Championship 2021 (Validação Funcional)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('TC-005: Status deve ser 200 OK', () => { pm.response.to.have.status(200); });",
              "pm.test('TC-005: Resposta deve ser JSON', () => { pm.response.to.be.json; });",
              "pm.test('TC-005: Tempo de resposta < 5000ms', () => { pm.expect(pm.response.responseTime).to.be.below(5000); });",
              "const jsonData = pm.response.json();",
              "pm.test('TC-005: Deve retornar lista de pilotos', () => {",
              "  pm.expect(jsonData.drivers_championship).to.be.an('array');",
              "  pm.expect(jsonData.drivers_championship.length).to.be.above(0)",
              "});",
              "pm.test('TC-005: Validar contrato básico', () => {",
              "  const piloto = jsonData.drivers_championship[0];",
              "  pm.expect(piloto.position).to.be.a('number');",
              "  pm.expect(piloto.driverId).to.be.a('string');",
              "  pm.expect(piloto.points).to.be.a('number');",
              "  pm.expect(piloto.wins).to.be.a('number');",
              "  pm.expect(piloto.teamId).to.be.a('string');",
              "  pm.expect(jsonData.season).to.eql(2021);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/2021/drivers-championship",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "2021",
            "drivers-championship"
          ]
        }
      },
      "response": []
    },
