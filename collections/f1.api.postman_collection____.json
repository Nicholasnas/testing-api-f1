{
  "info": {
    "_postman_id": "8d9b0b7b-6b5f-4e41-9d12--2026",
    "name": "F1 API Tests",
    "description": "Collection individual de testes realizados por Otavio Oliveira Jimenez para a F1 API - Inatel.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Testes de Sucesso (2xx)",
      "item": [
        {
          "name": "TC-006 - Listar pilotos da temporada 2024",
          "description": "Valida que o endpoint de pilotos por temporada retorna status 200, uma lista de pilotos e inclui Max Verstappen na temporada de 2024.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('TC-006: Status deve ser 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('TC-006: Validar pilotos da temporada 2024', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.drivers).to.be.an('array');",
                  "  pm.expect(jsonData.drivers.length).to.be.at.least(20);",
                  "  const hasMaxVerstappen = jsonData.drivers.some(driver => driver.driverId === 'max_verstappen');",
                  "  pm.expect(hasMaxVerstappen).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/2024/drivers",
              "host": ["{{baseUrl}}"],
              "path": ["2024", "drivers"]
            }
          }
        },
        {
          "name": "TC-007 - Listar circuitos da temporada 2024",
          "description": "Valida que o endpoint de circuitos por temporada retorna status 200, uma lista de circuitos e inclui Monaco na temporada de 2024.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('TC-007: Status deve ser 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('TC-007: Validar circuitos da temporada 2024', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.circuits).to.be.an('array');",
                  "  pm.expect(jsonData.circuits.length).to.be.at.least(20);",
                  "  const hasMonaco = jsonData.circuits.some(circuit => circuit.circuitId === 'monaco');",
                  "  pm.expect(hasMonaco).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/2024/circuits",
              "host": ["{{baseUrl}}"],
              "path": ["2024", "circuits"]
            }
          }
        }
      ]
    },
    {
      "name": "Testes de Erro (4xx)",
      "item": [
        {
          "name": "TC-015 - Buscar piloto inexistente por ID",
          "description": "Valida que ao buscar um piloto com ID inexistente a API retorna 404 e um corpo de erro consistente.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('TC-015: Deve retornar erro 404 para piloto inexistente', function () {",
                  "  pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('TC-015: Validar corpo de erro', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.status).to.eql(404);",
                  "  pm.expect(jsonData.message).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/drivers/driver_inexistente_xyz",
              "host": ["{{baseUrl}}"],
              "path": ["drivers", "driver_inexistente_xyz"]
            }
          }
        },
        {
          "name": "TC-016 - Buscar equipe inexistente por ID",
