{
  "info": {
    "name": "F1 API Tests",
    "description": "Collection of tests for the F1 API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "TC-001 - Drivers Endpoint Test",
      "description": "Testes para o endpoint /drivers",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/drivers",
          "host": ["{{baseUrl}}"],
          "path": ["drivers"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status deve ser 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Resposta deve ser um json', function () {",
              "    pm.response.to.be.json;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "TC-002 - Pesquisa de um Piloto expecifico",
      "description": "Testes para o endpoint de pesquisa de pilotos",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/drivers/search?q=verstappen",
          "host": ["{{baseUrl}}"],
          "path": ["drivers", "search"],
          "query": [{ "key": "q", "value": "verstappen" }]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('TC-002: Status deve ser 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('TC-002: Validar se retornou o Max Verstappen', function () {",
              "    var jsonData = pm.response.json();",
              "    var driver = jsonData.drivers.find(d => d.driverId === 'max_verstappen');",
              "    pm.expect(driver.surname).to.eql('Verstappen');",
              "    pm.expect(jsonData.total).to.be.at.least(1);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "TC-003 - Listar Temporadas Anteriores ",
      "description": "Testes para o endpoint /seasons",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/seasons",
          "host": ["{{baseUrl}}"],
          "path": ["seasons"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('TC-003: Status deve ser 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('TC-003: Validar se retornou as temporadas', function () {",
              "    var jsonData = pm.response.json();",
              "    // Acessando o array championships conforme o retorno real da API",
              "    pm.expect(jsonData.championships).to.be.an('array');",
              "    pm.expect(jsonData.championships.length).to.be.at.least(20);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "TC-011 - Buscar Temporada por Ano (funcionalidade inexistente)",
      "description": "Testes para o endpoint /seasons com /{ano}",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/races/2011",
          "host": ["{{baseUrl}}"],
          "path": ["races", "2011"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('TC-011: Deve retornar erro 404 para ano inválido', function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "pm.test('TC-011: Validar mensagem de erro', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.include('No seasons found');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "TC-012 - Pesquisar Piloto Inexistente",
      "description": "Testes de resposta para um search sem resposta",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/drivers/search?q=piloto_que_nao_existe",
          "host": ["{{baseUrl}}"],
          "path": ["drivers", "search"],
          "query": [{ "key": "q", "value": "piloto_que_nao_existe" }]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('TC-012: Status deve ser 404', function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "pm.test('TC-012: Validar mensagem de erro para busca vazia', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.eql('No drivers found.');",
              "    pm.expect(jsonData.status).to.eql(404);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}